# ZkCircles Backend Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Encryption Key (32 bytes hex = 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_character_hex_encryption_key

# Server Port
PORT=3001

# CORS - Frontend URL (for production)
# FRONTEND_URL=https://your-app.vercel.app

# ── Email Delivery (optional — pick ONE) ──────────────────────────────────────
# Option A: Resend (recommended — free, HTTP API, no SMTP needed)
# Sign up at https://resend.com, get an API key, verify your domain
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=ZkCircles <noreply@yourdomain.com>

# Option B: SMTP (Gmail, Outlook, Brevo, etc.)
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop
# SMTP_FROM=noreply@zkcircles.app

# If neither is set, the verification code is returned in the API response (testnet mode)
